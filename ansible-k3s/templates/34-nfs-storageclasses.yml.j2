---
# NFS CSI StorageClasses (one per nfs_shares entry); rendered when nfs_enabled. Plain NFS: no Secret referenced.
{% for share in nfs_shares %}
---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: "{{ share.name }}"
provisioner: nfs.csi.k8s.io
parameters:
  server: "{{ share.server }}"
  share: "{{ share.share }}"
reclaimPolicy: Delete
volumeBindingMode: Immediate
allowVolumeExpansion: true
{% set opts = share.mount_options | default(nfs_mount_options) | default([]) %}
{% if opts | length > 0 %}
mountOptions:
{% for opt in opts %}
  - {{ opt }}
{% endfor %}
{% endif %}
{% endfor %}