---
# Loki via HelmChart CR — monolithic, filesystem storage on a ceph-rbd PVC, targetNamespace monitoring.
# Release "loki" -> loki.monitoring.svc:3100. Community chart (grafana/helm-charts loki is GEL-only now).
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: loki
  namespace: kube-system
spec:
  repo: "{{ observability_loki_chart_repo }}"
  chart: loki
  version: "{{ observability_loki_chart_version }}"
  targetNamespace: {{ observability_namespace }}
  valuesContent: |-
    deploymentMode: Monolithic

    loki:
      auth_enabled: false
      commonConfig:
        path_prefix: /var/loki
        replication_factor: 1
      storage:
        type: filesystem
        filesystem:
          chunks_directory: /var/loki/chunks
          rules_directory: /var/loki/rules
      schemaConfig:
        configs:
          - from: "2024-04-01"
            store: tsdb
            object_store: filesystem
            schema: v13
            index:
              prefix: index_
              period: 24h
      compactor:
        working_directory: /var/loki/data/retention
        retention_enabled: true
        # filesystem store holds delete requests when retention is on — Loki refuses to start without it.
        delete_request_store: filesystem
        retention_delete_delay: 2h
      limits_config:
        retention_period: {{ observability_loki_retention }}

    singleBinary:
      enabled: true
      replicas: 1
      persistence:
        enabled: true
        accessModes:
          - ReadWriteOnce
        size: {{ observability_loki_storage }}
        storageClass: {{ ceph_sc_rbd_name }}

    # Zero out non-monolithic targets: chart defaults write/read/backend to replicas:3
    # (SimpleScalable); leaving them alongside singleBinary.replicas:1 fails chart validation.
    # Disable chunksCache/resultsCache (memcached STSs) — singleBinary caches in-process.
    backend:        { replicas: 0 }
    read:           { replicas: 0 }
    write:          { replicas: 0 }
    ingester:       { replicas: 0 }
    querier:        { replicas: 0 }
    queryFrontend:  { replicas: 0 }
    queryScheduler: { replicas: 0 }
    distributor:    { replicas: 0 }
    compactor:      { replicas: 0 }
    indexGateway:   { replicas: 0 }
    bloomPlanner:   { replicas: 0 }
    bloomBuilder:   { replicas: 0 }
    bloomGateway:   { replicas: 0 }
    chunksCache:    { enabled: false }
    resultsCache:   { enabled: false }

    minio:
      enabled: false
    gateway:
      enabled: false