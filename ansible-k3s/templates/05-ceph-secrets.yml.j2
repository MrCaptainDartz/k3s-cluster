---
apiVersion: v1
kind: Namespace
metadata:
  name: ceph-csi-operator-system
---
apiVersion: v1
kind: Secret
metadata:
  name: csi-rbd-secret
  namespace: ceph-csi-operator-system
stringData:
  userID: "{{ ceph_client_id }}"
  userKey: "{{ ceph_client_key }}"
---
apiVersion: v1
kind: Secret
metadata:
  name: csi-cephfs-secret
  namespace: ceph-csi-operator-system
stringData:
  userID: "{{ ceph_client_id }}"
  userKey: "{{ ceph_client_key }}"
