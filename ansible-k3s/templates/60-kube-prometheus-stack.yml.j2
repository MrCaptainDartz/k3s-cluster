---
# kube-prometheus-stack via HelmChart CR (Prometheus+Operator+Grafana+Alertmanager+kube-state-metrics+CRDs), targetNamespace monitoring.
# node-exporter DISABLED here (separate 63-); etcd/kcm/scheduler/kubeProxy disabled (K3s runs them in-process, not scrapable).
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: kube-prometheus-stack
  namespace: kube-system
spec:
  repo: "{{ observability_kps_chart_repo }}"
  chart: kube-prometheus-stack
  version: "{{ observability_kps_chart_version }}"
  targetNamespace: {{ observability_namespace }}
{% set telegram_configured = (observability_alertmanager_telegram_chat_id | int != 0) and (observability_alertmanager_telegram_bot_token | length > 0) and (observability_alertmanager_telegram_bot_token != "REDACTED") %}
  valuesContent: |-
    # node-exporter disabled (separate 63-). Gotcha: the subchart activation key is
    # `nodeExporter.enabled`, NOT `prometheus-node-exporter.enabled` — the latter is a
    # SILENT NO-OP in KPS v67+ (subchart renders anyway -> DS rejected on PSS -> rollout stuck).
    nodeExporter:
      enabled: false

    # K3s runs these in-process (no static pods) -> KPS scrapers have empty targets ->
    # false-positive *Down alerts. Unlike node-exporter above, these are internal KPS
    # components (not subcharts), so their `*.enabled` keys work directly.
    kubeEtcd:
      enabled: false
    kubeControllerManager:
      enabled: false
    kubeScheduler:
      enabled: false
    kubeProxy:
      enabled: false

    prometheus:
      prometheusSpec:
        retention: {{ observability_prometheus_retention }}
        scrapeInterval: {{ observability_scrape_interval }}
        # nil selectors => discover all ServiceMonitors/PodMonitors across namespaces (65-).
        serviceMonitorSelectorNilUsesHelmValues: false
        serviceMonitorSelector: {}
        serviceMonitorNamespaceSelector: {}
        podMonitorSelectorNilUsesHelmValues: false
        podMonitorSelector: {}
        podMonitorNamespaceSelector: {}
        storageSpec:
          volumeClaimTemplate:
            spec:
              storageClassName: {{ ceph_sc_rbd_name }}
              accessModes: ["ReadWriteOnce"]
              resources:
                requests:
                  storage: {{ observability_prometheus_storage }}

    # Alertmanager. Chart deep-merges a Watchdog route to receiver "null"; our receivers
    # override replaces the default, so we MUST re-declare a "null" no-op (QUOTED — a bare
    # null is the YAML null value, which Alertmanager rejects as an empty name).
    alertmanager:
      config:
        global:
          resolve_timeout: 5m
        route:
          group_by: ["alertname", "namespace"]
          group_wait: 30s
          group_interval: 5m
          repeat_interval: 4h
{% if telegram_configured %}
          receiver: telegram
{% else %}
          receiver: "null"
{% endif %}
        receivers:
          - name: "null"
{% if telegram_configured %}
          - name: telegram
            telegram_configs:
              - bot_token: "{{ observability_alertmanager_telegram_bot_token }}"
                chat_id: {{ observability_alertmanager_telegram_chat_id }}
                send_resolved: true
{% endif %}

    # Grafana — Ingress via Traefik; TLS added when cert-manager is enabled.
    grafana:
      adminPassword: {{ observability_grafana_admin_password }}
      persistence:
        enabled: true
        storageClassName: {{ ceph_sc_rbd_name }}
        size: 5Gi
      ingress:
        enabled: true
        ingressClassName: traefik
        hosts:
          - {{ observability_grafana_hostname }}
{% if certmanager_enabled | bool %}
        tls:
          - hosts:
              - {{ observability_grafana_hostname }}
            secretName: grafana-tls
        annotations:
          cert-manager.io/cluster-issuer: {{ observability_grafana_tls_issuer }}
{% endif %}
      # Loki datasource (logs) from 61- -> http://loki.<ns>.svc:3100; Prometheus kept as default.
      additionalDataSources:
        - name: Loki
          type: loki
          access: proxy
          url: http://loki.{{ observability_namespace }}.svc:3100
          isDefault: false
          jsonData:
            maxLines: 1000