---
# HelmChartConfig overlay for K3s-packaged Traefik (do NOT edit traefik.yaml — rewritten on startup).
# GOTCHA: chart v40 reads deployment.kind (DaemonSet), NOT top-level kind — a silent no-op leaving 1-replica Deployment. ports.<name>.expose is a map {default: bool}.
# HTTP->HTTPS redirect; dashboard exposed at :8080 (UNAUTHENTICATED, LAN-only); fixed LB IP via metallb.io/loadBalancerIPs (spec.loadBalancerIP deprecated).
apiVersion: helm.cattle.io/v1
kind: HelmChartConfig
metadata:
  name: traefik
  namespace: kube-system
spec:
  valuesContent: |-
    deployment:
      kind: DaemonSet
    tolerations:
      - key: "node-role.kubernetes.io/control-plane"
        operator: "Exists"
        effect: "NoSchedule"
      - key: "node-role.kubernetes.io/master"
        operator: "Exists"
        effect: "NoSchedule"
    globalArguments: []
    ports:
      web:
        http:
          redirections:
            entryPoint:
              to: websecure
              scheme: https
              permanent: true
      traefik:
        expose:
          default: true
        exposedPort: 8080
      # Metrics :9100 exposed on LB so 65- ServiceMonitor scrapes port "metrics"; safe (cluster behind firewall, LAN-only).
      metrics:
        expose:
          default: true
        exposedPort: 9100
    ingressRoute:
      dashboard:
        enabled: true
    service:
      annotations:
        metallb.io/loadBalancerIPs: "{{ traefik_lb_ip }}"