---
# PSS: label-based namespace admission. Labelled ns: enforce=baseline, audit+warn=restricted.
# Unlabelled ns (kube-system, metallb-system, ceph-csi-operator-system, observability-host)
# stay privileged — K3s sets no cluster-wide default so unlabelled is truly unrestricted.
apiVersion: v1
kind: Namespace
metadata:
  name: default
  labels:
    pod-security.kubernetes.io/enforce: baseline
    pod-security.kubernetes.io/enforce-version: latest
    pod-security.kubernetes.io/audit: restricted
    pod-security.kubernetes.io/audit-version: latest
    pod-security.kubernetes.io/warn: restricted
    pod-security.kubernetes.io/warn-version: latest
{% if certmanager_enabled | bool %}
---
apiVersion: v1
kind: Namespace
metadata:
  name: cert-manager
  labels:
    pod-security.kubernetes.io/enforce: baseline
    pod-security.kubernetes.io/enforce-version: latest
    pod-security.kubernetes.io/audit: restricted
    pod-security.kubernetes.io/audit-version: latest
    pod-security.kubernetes.io/warn: restricted
    pod-security.kubernetes.io/warn-version: latest
{% endif %}
{% if certmanager_enabled | bool and (certmanager_dns_credentials | default([]) | selectattr('provider', 'equalto', 'infomaniak') | list | length > 0) %}
---
apiVersion: v1
kind: Namespace
metadata:
  name: cert-manager-infomaniak
  labels:
    pod-security.kubernetes.io/enforce: baseline
    pod-security.kubernetes.io/enforce-version: latest
    pod-security.kubernetes.io/audit: restricted
    pod-security.kubernetes.io/audit-version: latest
    pod-security.kubernetes.io/warn: restricted
    pod-security.kubernetes.io/warn-version: latest
{% endif %}
{% if observability_enabled | bool %}
---
# monitoring — baseline-enforced (pre-created here; patched by 60-/61-).
apiVersion: v1
kind: Namespace
metadata:
  name: {{ observability_namespace }}
  labels:
    pod-security.kubernetes.io/enforce: baseline
    pod-security.kubernetes.io/enforce-version: latest
    pod-security.kubernetes.io/audit: restricted
    pod-security.kubernetes.io/audit-version: latest
    pod-security.kubernetes.io/warn: restricted
    pod-security.kubernetes.io/warn-version: latest
---
# observability-host — UNLABELLED (exempt): host DaemonSets that violate baseline.
apiVersion: v1
kind: Namespace
metadata:
  name: {{ observability_host_namespace }}
{% endif %}