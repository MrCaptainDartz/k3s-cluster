---
# OVH DNS-01 webhook for cert-manager (aureq chart, via a HelmChart CR).
# Deployed only when certmanager_enabled AND an OVH cred exists (site.yml).
# groupName MUST match the OVH solvers in 24-certmanager-issuers.yml.j2.
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: cert-manager-webhook-ovh
  namespace: kube-system
spec:
  repo: "{{ certmanager_webhook_ovh_chart_repo }}"
  chart: cert-manager-webhook-ovh
  version: "{{ certmanager_webhook_ovh_chart_version }}"
  targetNamespace: cert-manager
  valuesContent: |-
    groupName: {{ certmanager_webhook_group_ovh }}
    certManager:
      namespace: cert-manager
      serviceAccountName: cert-manager