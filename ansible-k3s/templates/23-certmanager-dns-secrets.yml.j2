---
# DNS-01 creds: one Opaque Secret per certmanager_dns_credentials entry; stringData keys per provider. Values from vault all.yml (never cleartext).
{% for cred in certmanager_dns_credentials %}
---
apiVersion: v1
kind: Secret
metadata:
  name: "{{ cred.secret_name }}"
  namespace: cert-manager
type: Opaque
stringData:
{% if cred.provider == "cloudflare" %}
  token: "{{ cred.token }}"
{% elif cred.provider == "infomaniak" %}
  api-token: "{{ cred.token }}"
{% elif cred.provider == "ovh" %}
  applicationKey: "{{ cred.application_key }}"
  applicationSecret: "{{ cred.application_secret }}"
  applicationConsumerKey: "{{ cred.consumer_key }}"
{% endif %}
{% endfor %}