---
# DNS-01 provider credentials: one Opaque Secret per certmanager_dns_credentials
# entry, in cert-manager. stringData keys per provider (cf/ovh/infomaniak),
# referenced by the solvers in 24-certmanager-issuers.yml.j2. Values come from
# vault-protected all.yml — never committed cleartext.
{% for cred in certmanager_dns_credentials %}
---
apiVersion: v1
kind: Secret
metadata:
  name: "{{ cred.secret_name }}"
  namespace: cert-manager
type: Opaque
stringData:
{% if cred.provider == "cloudflare" %}
  token: "{{ cred.token }}"
{% elif cred.provider == "infomaniak" %}
  api-token: "{{ cred.token }}"
{% elif cred.provider == "ovh" %}
  applicationKey: "{{ cred.application_key }}"
  applicationSecret: "{{ cred.application_secret }}"
  applicationConsumerKey: "{{ cred.consumer_key }}"
{% endif %}
{% endfor %}