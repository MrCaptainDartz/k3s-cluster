---
# Ceph CSI NetworkPolicies — deny-all + targeted egress for ceph-csi-operator-system.
# Operator (54-) creates the ns; this (56) applies after. CSI node plugins run
# hostNetwork (not enforced). Egress: ceph_subnet (mon 3300/6789, OSD/mgr 6800-7300), kube-api, DNS.
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: default-deny-all
  namespace: ceph-csi-operator-system
spec:
  podSelector: {}
  policyTypes:
    - Ingress
    - Egress
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-egress-ceph
  namespace: ceph-csi-operator-system
spec:
  podSelector: {}
  policyTypes:
    - Egress
  egress:
    - to:
        - ipBlock:
            cidr: {{ ceph_subnet }}
      ports:
        - protocol: TCP
          port: 3300
        - protocol: TCP
          port: 6789
        - protocol: TCP
          port: 6800
          endPort: 7300
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-egress-kubeapi
  namespace: ceph-csi-operator-system
spec:
  podSelector: {}
  policyTypes:
    - Egress
  egress:
    - to:
        - ipBlock:
            cidr: {{ node_cidr }}
      ports:
        - protocol: TCP
          port: 6443
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-egress-dns
  namespace: ceph-csi-operator-system
spec:
  podSelector: {}
  policyTypes:
    - Egress
  egress:
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
          podSelector:
            matchLabels:
              k8s-app: kube-dns
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53
---
# Prometheus scrape allow (if observability) — operator metrics :8081.
{% if observability_enabled | bool %}
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-ingress-from-prometheus
  namespace: ceph-csi-operator-system
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: ceph-csi-operator
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: {{ observability_namespace }}
          podSelector:
            matchLabels:
              app.kubernetes.io/name: prometheus
      ports:
        - protocol: TCP
          port: 8081
{% endif %}