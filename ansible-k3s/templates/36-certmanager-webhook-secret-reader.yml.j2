---
# Grants the OVH/Infomaniak webhooks read access to their cred Secrets (33-...).
# Their bundled RBAC doesn't cover arbitrary/multiple cred names: the OVH chart
# emits a secret-reader Role only when it creates its own issuers (we don't), and
# the Infomaniak manifest hardcodes one secret name. So we grant each webhook
# get/watch on its provider's cred Secrets by name (free naming + multi-cred).
# Scoped to cert-manager only; distinct name (`:cred-reader`) avoids clashing
# with the Infomaniak manifest's own Role in the same namespace.
{% set ovh_secrets = certmanager_dns_credentials | selectattr('provider', 'equalto', 'ovh') | map(attribute='secret_name') | list %}
{% set info_secrets = certmanager_dns_credentials | selectattr('provider', 'equalto', 'infomaniak') | map(attribute='secret_name') | list %}
{% if ovh_secrets | length > 0 %}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: cert-manager-webhook-ovh:cred-reader
  namespace: cert-manager
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "watch"]
    resourceNames:
{% for s in ovh_secrets %}
      - "{{ s }}"
{% endfor %}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: cert-manager-webhook-ovh:cred-reader
  namespace: cert-manager
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: cert-manager-webhook-ovh:cred-reader
subjects:
  - kind: ServiceAccount
    name: cert-manager-webhook-ovh
    namespace: cert-manager
{% endif %}
{% if info_secrets | length > 0 %}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: infomaniak-webhook:cred-reader
  namespace: cert-manager
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "watch"]
    resourceNames:
{% for s in info_secrets %}
      - "{{ s }}"
{% endfor %}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: infomaniak-webhook:cred-reader
  namespace: cert-manager
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: infomaniak-webhook:cred-reader
subjects:
  - kind: ServiceAccount
    name: infomaniak-webhook
    namespace: cert-manager-infomaniak
{% endif %}