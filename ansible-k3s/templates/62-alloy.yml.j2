---
# Alloy log shipper via HelmChart CR — DaemonSet in observability-host (exempt), FILE-based (tails /var/log/pods hostPath).
# File-based not API-based: 64- egress NP allows ONLY Loki:3100+DNS:53, so loki.source.kubernetes can't reach the
# kube-apiserver -> 0 targets -> zero logs. File reads node fs only; pod-net binds the NP; DaemonSet = no 3x duplication.
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: alloy
  namespace: kube-system
spec:
  repo: "{{ observability_alloy_chart_repo }}"
  chart: alloy
  version: "{{ observability_alloy_chart_version }}"
  targetNamespace: {{ observability_host_namespace }}
  valuesContent: |-
    controller:
      type: daemonset
      hostNetwork: false
      volumes:
        extra:
          # Host machine-id so loki.source.journal resolves the host's journal dir
          # /var/log/journal/<machine-id>/ (the container's own machine-id wouldn't match).
          - name: machine-id
            hostPath:
              path: /etc/machine-id
              type: File

    alloy:
      # Mount /var/log so loki.source.file tails /var/log/pods/<ns>_<pod>_<uid>/<container>/*.log. K3s writes
      # REAL files here (no /var/lib/docker/containers needed). Gotcha: top-level `extraVolumes`/
      # `extraVolumeMounts` are SILENTLY IGNORED — use `alloy.mounts.*` (container) + `controller.volumes.*` (pod).
      mounts:
        varlog: true
        # /var/log (via varlog above) already covers /var/log/journal once persistent journald is on.
        # Overlay the host machine-id (see controller.volumes.extra).
        extra:
          - name: machine-id
            mountPath: /etc/machine-id
            readOnly: true
      # Run as root so the journal files (root:systemd-journal, 0640) are readable — the container's
      # alloy user isn't in systemd-journal. The namespace is PSS-exempt (unlabelled), so root is allowed.
      securityContext:
        runAsUser: 0
        runAsGroup: 0
      configMap:
        create: true
        content: |-
          logging {
            level  = "info"
            format = "logfmt"
          }

          // Discover pod logs on THIS node via local.file_match (fsnotify, reads fs — NO kube-apiserver access,
          // works under the 64- NP). DaemonSet tails only its own node (no 3x duplication). Positions live in
          // --storage.path (/tmp/alloy, ephemeral): restart re-reads existing files once; persist later if needed.
          local.file_match "pods" {
            path_targets = [
              {
                __path__ = "/var/log/pods/*/*/*.log",
              },
            ]
          }

          // Derive labels from __path__ + node name from K8S_NODE_NAME env. No app/pod labels — those need
          // the API server, blocked by the egress NP; namespace+pod+container+node is enough to query Loki.
          discovery.relabel "pods" {
            targets = local.file_match.pods.targets

            rule {
              source_labels = ["__path__"]
              regex         = "/var/log/pods/([^_]+)_([^_]+)_[^/]+/([^/]+)/.*"
              target_label  = "namespace"
              replacement   = "$1"
              action        = "replace"
            }
            rule {
              source_labels = ["__path__"]
              regex         = "/var/log/pods/([^_]+)_([^_]+)_[^/]+/([^/]+)/.*"
              target_label  = "pod"
              replacement   = "$2"
              action        = "replace"
            }
            rule {
              source_labels = ["__path__"]
              regex         = "/var/log/pods/([^_]+)_([^_]+)_[^/]+/([^/]+)/.*"
              target_label  = "container"
              replacement   = "$3"
              action        = "replace"
            }
            rule {
              target_label = "node"
              replacement  = sys.env("K8S_NODE_NAME")
              action       = "replace"
            }
          }

          loki.source.file "pods" {
            targets    = discovery.relabel.pods.output
            forward_to = [loki.write.loki.receiver]
          }

          // K3s control-plane components (apiserver/scheduler/controller-manager/etcd) run in the single
          // k3s process and log to the host's journald unit (k3s.service on control nodes, k3s-agent.service
          // on workers) — interleaved, no per-component tag. loki.source.journal scans /var/log/journal
          // (mounted via varlog + /etc/machine-id overlay so the host machine-id is resolved). matches="" =
          // all units; relabel exposes the systemd unit as a label so Loki can filter (e.g. {unit="k3s.service"}).
          // No network: reads host fs only -> the 64- egress NP (Loki+DNS) needs no change.
          discovery.relabel "journal" {
            targets = []

            rule {
              source_labels = ["__journal__systemd_unit"]
              target_label  = "unit"
            }
            rule {
              target_label = "job"
              replacement  = "journald"
            }
            rule {
              target_label = "node"
              replacement  = sys.env("K8S_NODE_NAME")
            }
          }

          loki.source.journal "k3s" {
            forward_to    = [loki.write.loki.receiver]
            relabel_rules = discovery.relabel.journal.rules
          }

          loki.write "loki" {
            endpoint {
              url = "http://loki.{{observability_namespace}}.svc:3100/loki/api/v1/push"
            }
          }