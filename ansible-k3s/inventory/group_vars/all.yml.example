---
# ============================================================
# K3s — Core Configuration
# ============================================================

k3s_api_port: "6443"

# K3s version. PINNED (not the moving "stable" channel): a bump silently changes
# Traefik's chart version/schema and breaks the HelmChartConfig. Bump deliberately.
k3s_release_version: "v1.36.2+k3s1"

# Use embedded etcd as the datastore (recommended for 3 control planes)
k3s_etcd_datastore: true

# Scheduled etcd snapshots (embedded etcd only), stored under
# /var/lib/rancher/k3s/server/db/snapshots/ and pruned to retention.
# Restore with: `k3s etcd-snapshot ...` (see README).
k3s_etcd_snapshot_cron: "0 */6 * * *"   # every 6 hours
k3s_etcd_snapshot_retention: "28"       # ~7 days at 6h intervals

# Enable privilege escalation for K3s installation
k3s_become: true

# Address used by nodes to join the cluster (set to kube-vip VIP)
k3s_registration_address: "{{ k3s_vip }}"

# ============================================================
# K3s — Server (Control Plane) Configuration
# ============================================================

# Disable servicelb (replaced by MetalLB) and local-storage (we use Ceph + NFS/SMB).
# Traefik is kept and customized via HelmChartConfig (see Traefik section below).
k3s_disabled_components:
  - servicelb
  - local-storage

k3s_server:
  disable: "{{ k3s_disabled_components }}"
  tls-san:
    - "{{ k3s_vip }}"
  disable-cloud-controller: true
  # 0600: /etc/rancher/k3s/k3s.yaml holds the cluster admin cert — must NOT be
  # world/group-readable (0644 lets any local user become cluster admin).
  write-kubeconfig-mode: "0600"
  flannel-backend: "host-gw"
  etcd-snapshot-schedule-cron: "{{ k3s_etcd_snapshot_cron }}"
  etcd-snapshot-retention: "{{ k3s_etcd_snapshot_retention }}"

# ============================================================
# CoreDNS — HA replica count
# ============================================================
# CoreDNS addon has no replicas field since v1.25.5, so kubectl scale persists
# and no K3s flag exists; re-asserted by a post_tasks step in site.yml.
# topologySpread gives one-per-node HA (3 = survives one node loss, no DNS gap).
coredns_replicas: 3

# ============================================================
# kube-vip — Control Plane Virtual IP
# ============================================================

# Virtual IP address for the K3s API server (must be free on the network)
k3s_vip: "192.168.1.10"

# Node interface for the VIP (ARP mode). Empty ("") -> auto-resolved by a pre_task
# in site.yml to the NIC matching node_cidr (robust on multi-NIC nodes where the
# default route may be a storage NIC). Set explicitly (e.g. "ens18") to override.
k3s_vip_interface: ""

# kube-vip container image and version
kube_vip_image: "ghcr.io/kube-vip/kube-vip"
kube_vip_version: "v1.2.1"

# Node network CIDR (control planes + workers); cert-manager NP allows API :6443 from here.
node_cidr: "192.168.1.0/24"

# Pod CIDR (k3s cluster-cidr). cert-manager admission webhook NP also allows the
# API here: host-gw flannel sources same-node calls from cni0 gw (this CIDR),
# cross-node from node IP (node_cidr). See 25-certmanager-network-policies.yml.j2.
cluster_cidr: "10.42.0.0/16"

# ============================================================
# Ceph CSI
# ============================================================

# StorageClass names. ceph-rbd (default, Delete) + ceph-rbd-retain (Retain, for data you can't
# regenerate: DBs, important app data) + ceph-cephfs (Retain, shared/durable FS). Pick by DATA VALUE,
# not storage type — the default (Delete) is dangerous for non-reproducible data. See 51-.
ceph_sc_rbd_name: "ceph-rbd"
ceph_sc_rbd_retain_name: "ceph-rbd-retain"
ceph_sc_cephfs_name: "ceph-cephfs"

ceph_csi_operator_version: "v1.0.4"

# Ceph user (e.g. admin or kubernetes)
ceph_client_id: "admin"

# Ceph client secret key — SECRET, real value in gitignored all.yml only.
ceph_client_key: "YOUR-CEPH-ADMIN-KEYRING-HERE"

# Ceph monitor IPs
ceph_monitors:
  - "192.168.1.200"
  - "192.168.1.201"
  - "192.168.1.202"

# Ceph storage network CIDR. The CSI provisioner connects to monitors AND OSDs
# directly, so the NP allows egress to this whole subnet (ports 3300/6789/6800-7300),
# not just monitor IPs. Must cover monitors + OSDs + mgrs.
ceph_subnet: "192.168.1.0/24"

# Names of resources
ceph_rbd_pool: "pool1_ssd"
cephfs_fs_name: "cephfs1_ssd"

# CephFS subvolume group used by the CSI driver (must exist in Ceph)
cephfs_subvolumegroup: "csi"

# ============================================================
# MetalLB — LoadBalancer
# ============================================================

# MetalLB version to install
metallb_version: "v0.16.1"

# IP range for MetalLB (same L2 as nodes, no overlap with DHCP/static IPs)
metallb_ip_range: "192.168.1.150-192.168.1.199"

# Name of the MetalLB IP pool
metallb_pool_name: "default-pool"

# ============================================================
# Traefik (K3s-packaged Ingress Controller)
# ============================================================
# Kept (not disabled), customized via HelmChartConfig (12-traefik-config.yml.j2):
# DaemonSet, HTTP->HTTPS redirect, dashboard IngressRoute, no usage calls. Only
# traefik_lb_ip is set here (pins LB IP via metallb.io annotation; metallb.universe.tf
# is deprecated since v0.14). See README.

# Fixed MetalLB IP for Traefik's LB Service (within metallb_ip_range, free).
traefik_lb_ip: "192.168.1.199"

# ============================================================
# cert-manager (optional) — real TLS via Let's Encrypt DNS-01
# ============================================================
# Flip to deploy cert-manager + Let's Encrypt ClusterIssuers (staging + prod).
# DNS providers (cloudflare built-in; ovh/infomaniak via webhooks) routed by
# domain. Tokens/keys are SECRET — gitignored all.yml only, never in this example.
certmanager_enabled: false

# cert-manager release (official cert-manager.yaml is pulled from this tag).
certmanager_version: "v1.21.0"

# Email registered with Let's Encrypt (expiry notices).
certmanager_acme_email: "you@example.com"

# ACME servers -> one ClusterIssuer each. Staging: untrusted, no rate-limit; prod: real.
certmanager_acme_servers:
  - name: "letsencrypt-staging"
    server: "https://acme-staging-v02.api.letsencrypt.org/directory"
  - name: "letsencrypt-prod"
    server: "https://acme-v02.api.letsencrypt.org/directory"

# DNS credentials: one entry per (provider/token), routed by match_domains. Bare
# zone covers apex/wildcard/subdomains. Fields: cloudflare=token; ovh=endpoint,
# application_key,application_secret,consumer_key; infomaniak=token.
certmanager_dns_credentials:
  - name: "cloudflare-main"
    provider: "cloudflare"
    secret_name: "cloudflare-api-token-main"
    token: "REDACTED"
    match_domains: ["example.tld"]
  - name: "ovh-other"
    provider: "ovh"
    secret_name: "ovh-creds-other"
    endpoint: "ovh-eu"
    application_key: "REDACTED"
    application_secret: "REDACTED"
    consumer_key: "REDACTED"
    match_domains: ["other.tld"]
  - name: "infomaniak-third"
    provider: "infomaniak"
    secret_name: "infomaniak-api-token-third"
    token: "REDACTED"
    match_domains: ["third.tld"]

# OVH webhook: groupName must match the webhook.groupName in the OVH solvers (unique).
certmanager_webhook_group_ovh: "acme.myhomelab.example"
certmanager_webhook_ovh_chart_version: "0.9.14"
certmanager_webhook_ovh_chart_repo: "https://aureq.github.io/cert-manager-webhook-ovh"

# Infomaniak webhook: official rendered manifest (groupName baked in by publisher).
certmanager_webhook_infomaniak_version: "v0.3.1"

# ============================================================
# Observability (optional) — kube-prometheus-stack + Loki + Alloy
# ============================================================
# Flip to deploy the monitoring baseline (Prometheus+Operator+Grafana+Alertmanager+
# kube-state-metrics; node-exporter separate; Loki logs; Alloy shipper) via HelmChart
# CRs (60-65). Secrets (Telegram token, Grafana admin pw) — gitignored all.yml only.
observability_enabled: false

# Namespaces (match 13-pod-security.yml.j2 + the HelmChart targetNamespaces).
observability_namespace: "monitoring"
observability_host_namespace: "observability-host"

# Chart repos + pinned versions (bump deliberately). Loki uses the community chart
# (grafana/helm-charts loki is GEL-only); filesystem storage on PVC, minio disabled.
observability_kps_chart_repo: "https://prometheus-community.github.io/helm-charts"
observability_kps_chart_version: "87.15.1"
observability_loki_chart_repo: "https://grafana-community.github.io/helm-charts"
observability_loki_chart_version: "18.4.4"
observability_alloy_chart_repo: "https://grafana.github.io/helm-charts"
observability_alloy_chart_version: "1.10.1"
observability_node_exporter_chart_repo: "https://prometheus-community.github.io/helm-charts"
observability_node_exporter_chart_version: "4.56.0"

# Prometheus/Loki retention + PVC sizes (ceph-rbd); scrape interval for all monitors.
observability_prometheus_retention: "15d"
observability_prometheus_storage: "20Gi"
observability_loki_retention: "7d"
observability_loki_storage: "10Gi"
observability_scrape_interval: "30s"

# Grafana Ingress hostname (TLS added when certmanager_enabled) + prod issuer name
# (MUST match a certmanager_acme_servers entry).
observability_grafana_hostname: "grafana.example.com"
observability_grafana_tls_issuer: "letsencrypt-prod"

# Alertmanager Telegram receiver (native telegram_configs). bot_token from @BotFather;
# chat_id is int (negative for groups). SECRET — gitignored all.yml only; 0=not configured.
observability_alertmanager_telegram_bot_token: "REDACTED"
observability_alertmanager_telegram_chat_id: 0

# Grafana initial admin password (change after first login). SECRET — gitignored all.yml only.
observability_grafana_admin_password: "REDACTED"

# ============================================================
# NFS CSI (optional) — access existing NFS shares (e.g. a NAS export)
# ============================================================
# Set true to deploy the kubernetes-csi NFS driver + one StorageClass per share in
# nfs_shares. No operator (raw manifests, like MetalLB/ceph-csi). Plain NFS, no creds.
nfs_enabled: false

# Release tag of kubernetes-csi/csi-driver-nfs
nfs_csi_version: "v4.13.4"

# Default mountOptions for every NFS StorageClass; a share can override via mount_options.
nfs_mount_options:
  - "nfsvers=4.1"

# One StorageClass per entry (cluster-scoped, named per share). Set [] for driver-only.
# Each share: name (SC name), server, share (export path), mount_options (opt).
nfs_shares:
  - name: "nfs-media"
    server: "nas.example.com"
    share: "/export/media"
  - name: "nfs-backup"
    server: "nas2.example.com"
    share: "/export/backup"
    mount_options:
      - "nfsvers=4.1"
      - "ro"

# ============================================================
# SMB CSI (optional) — access existing SMB/CIFS shares (e.g. a NAS)
# ============================================================
# Set true to deploy the kubernetes-csi SMB driver + one StorageClass per share.
# Creds are PER-NAMESPACE: each StorageClass resolves its Secret (smb_secret_name)
# in the PVC's own namespace via ${pvc.namespace} — you create it there, not here
# (creds live with each app, vault-protected). cifs-utils bundled in node image;
# host cifs-utils only for Kerberos (sec=krb5) mounts.
smb_enabled: false

# Release tag of kubernetes-csi/csi-driver-smb
smb_csi_version: "v1.20.3"

# Name of the Secret the StorageClasses expect in each consuming namespace.
smb_secret_name: "csi-smb-creds"

# Default mountOptions for every SMB StorageClass; a share can override. noserverino
# is REQUIRED to avoid data corruption.
smb_mount_options:
  - "dir_mode=0777"
  - "file_mode=0777"
  - "noperm"
  - "mfsymlinks"
  - "cache=strict"
  - "noserverino"

# One StorageClass per entry (cluster-scoped). Set [] for driver-only. Each share:
#   name (SC name), source (UNC path e.g. //nas/photos), mount_options (opt).
smb_shares:
  - name: "smb-photos"
    source: "//nas.example.com/photos"
  - name: "smb-movies"
    source: "//nas.example.com/movies"

# ============================================================
# K3s — Auto-deployed Manifests
# ============================================================

# Manifests downloaded from URLs and placed in /var/lib/rancher/k3s/server/manifests/
k3s_server_manifests_urls:
  - url: "https://raw.githubusercontent.com/metallb/metallb/{{ metallb_version }}/config/manifests/metallb-native.yaml"
    filename: 03-metallb-native.yaml

# Manifests rendered from Jinja2 templates and placed in /var/lib/rancher/k3s/server/manifests/
k3s_server_manifests_templates:
  - 01-kube-vip-rbac.yml.j2
  - 02-kube-vip-daemonset.yml.j2
  - 04-metallb-config.yml.j2
  - 11-network-policies.yml.j2
  - 12-traefik-config.yml.j2
  - 13-pod-security.yml.j2

# ------------------------------------------------------------
# Ceph CSI manifests (always-on primary storage, own group 50-56)
# ------------------------------------------------------------
# Ceph is always-on primary storage (no *_enabled flag); site.yml appends these
# unconditionally. 54- creates the operator namespace, so 56- NP must come after
# (fire-and-forget, applied in filename order).
ceph_manifest_urls:
  - url: "https://raw.githubusercontent.com/ceph/ceph-csi-operator/{{ ceph_csi_operator_version }}/deploy/multifile/crd.yaml"
    filename: 52-ceph-csi-operator-crd.yaml
  - url: "https://raw.githubusercontent.com/ceph/ceph-csi-operator/{{ ceph_csi_operator_version }}/deploy/multifile/csi-rbac.yaml"
    filename: 53-ceph-csi-operator-rbac.yaml
  - url: "https://raw.githubusercontent.com/ceph/ceph-csi-operator/{{ ceph_csi_operator_version }}/deploy/multifile/operator.yaml"
    filename: 54-ceph-csi-operator.yaml

ceph_manifest_templates:
  - 50-ceph-secrets.yml.j2
  - 51-ceph-storageclasses.yml.j2
  - 55-ceph-csi-operator-config.yml.j2
  - 56-ceph-network-policies.yml.j2

# ------------------------------------------------------------
# Optional CSI driver manifests (NFS / SMB)
# ------------------------------------------------------------
# These sub-lists are NOT part of k3s_server_manifests_* by default; site.yml
# appends them only when the matching *_enabled flag is true (an inline Jinja
# if-tag is invalid in a YAML list in a vars file, so composition happens in the playbook).
#
# Manifest numbering (applied in filename order, no overlap):
#   01-13  baseline (kube-vip, MetalLB, NP, Traefik, Pod Security) -> k3s_server_manifests_*
#   20-26  cert-manager (url 20-21 + templates 22-26)
#   30-34  NFS CSI | 40-44  SMB CSI
#   50-56  Ceph CSI (always-on) | 60-65  Observability (HelmChart CRs, opt-in)
# Within a range driver/CRDs come before the StorageClasses/policies that depend on them.
nfs_manifest_urls:
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/{{ nfs_csi_version }}/deploy/{{ nfs_csi_version }}/rbac-csi-nfs.yaml"
    filename: 30-nfs-rbac.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/{{ nfs_csi_version }}/deploy/{{ nfs_csi_version }}/csi-nfs-driverinfo.yaml"
    filename: 31-nfs-driverinfo.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/{{ nfs_csi_version }}/deploy/{{ nfs_csi_version }}/csi-nfs-controller.yaml"
    filename: 32-nfs-controller.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/{{ nfs_csi_version }}/deploy/{{ nfs_csi_version }}/csi-nfs-node.yaml"
    filename: 33-nfs-node.yaml
nfs_manifest_templates:
  - 34-nfs-storageclasses.yml.j2

smb_manifest_urls:
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-smb/{{ smb_csi_version }}/deploy/{{ smb_csi_version }}/rbac-csi-smb.yaml"
    filename: 40-smb-rbac.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-smb/{{ smb_csi_version }}/deploy/{{ smb_csi_version }}/csi-smb-driver.yaml"
    filename: 41-smb-driver.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-smb/{{ smb_csi_version }}/deploy/{{ smb_csi_version }}/csi-smb-controller.yaml"
    filename: 42-smb-controller.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-smb/{{ smb_csi_version }}/deploy/{{ smb_csi_version }}/csi-smb-node.yaml"
    filename: 43-smb-node.yaml
smb_manifest_templates:
  - 44-smb-storageclasses.yml.j2

# ------------------------------------------------------------
# Optional cert-manager manifests
# ------------------------------------------------------------
# Like NFS/SMB, not part of k3s_server_manifests_* by default; site.yml appends
# when certmanager_enabled. DNS webhooks (OVH/Infomaniak) added only when a cred
# of that provider is present (computed in site.yml from certmanager_dns_credentials).
certmanager_manifest_urls:
  - url: "https://github.com/cert-manager/cert-manager/releases/download/{{ certmanager_version }}/cert-manager.yaml"
    filename: 20-cert-manager.yaml
certmanager_manifest_templates:
  - 23-certmanager-dns-secrets.yml.j2
  - 24-certmanager-issuers.yml.j2
  - 25-certmanager-network-policies.yml.j2
  - 26-certmanager-webhook-secret-reader.yml.j2
certmanager_webhook_ovh_templates:
  - 22-certmanager-webhook-ovh.yml.j2
certmanager_webhook_infomaniak_urls:
  - url: "https://github.com/Infomaniak/cert-manager-webhook-infomaniak/releases/download/{{ certmanager_webhook_infomaniak_version }}/rendered-manifest.yaml"
    filename: 21-certmanager-webhook-infomaniak.yaml

# ------------------------------------------------------------
# Optional observability manifests
# ------------------------------------------------------------
# Appended by site.yml only when observability_enabled. All are HelmChart CRs (no URLs).
# 65- (ServiceMonitors/Rules) needs 60- CRDs -> applies on 2nd boot (fire-and-forget).
observability_manifest_urls: []
observability_manifest_templates:
  - 60-kube-prometheus-stack.yml.j2
  - 61-loki.yml.j2
  - 62-alloy.yml.j2
  - 63-node-exporter.yml.j2
  - 64-observability-network-policies.yml.j2
  - 65-observability-rules.yml.j2
