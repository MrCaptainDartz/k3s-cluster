---
# ============================================================
# K3s — Core Configuration
# ============================================================

k3s_api_port: "6443"

# K3s version channel or specific version (e.g., "stable", "v1.31.2+k3s1")
k3s_release_version: stable

# Use embedded etcd as the datastore (recommended for 3 control planes)
k3s_etcd_datastore: true

# Scheduled etcd snapshots (embedded etcd only). Snapshots run on every
# control-plane node and are stored under
# /var/lib/rancher/k3s/server/db/snapshots/, pruned to k3s_etcd_snapshot_retention.
# Restore with: `k3s etcd-snapshot ...` (see README).
k3s_etcd_snapshot_cron: "0 */6 * * *"   # every 6 hours
k3s_etcd_snapshot_retention: "28"       # ~7 days at 6h intervals

# Enable privilege escalation for K3s installation
k3s_become: true

# Address used by nodes to join the cluster (set to kube-vip VIP)
k3s_registration_address: "{{ k3s_vip }}"

# ============================================================
# K3s — Server (Control Plane) Configuration
# ============================================================

# Components to disable in K3s
# - servicelb: replaced by MetalLB (Traefik's LoadBalancer Service gets a
#   MetalLB IP)
# - local-storage: we use Ceph (RBD/CephFS) + optional NFS/SMB CSI
# Traefik is KEPT (the K3s-packaged Ingress Controller) and customized via a
# HelmChartConfig — see the "Traefik (Ingress)" section below.
k3s_disabled_components:
  - servicelb
  - local-storage

k3s_server:
  disable: "{{ k3s_disabled_components }}"
  tls-san:
    - "{{ k3s_vip }}"
  disable-cloud-controller: true
  write-kubeconfig-mode: "0644"
  flannel-backend: "host-gw"
  etcd-snapshot-schedule-cron: "{{ k3s_etcd_snapshot_cron }}"
  etcd-snapshot-retention: "{{ k3s_etcd_snapshot_retention }}"

# ============================================================
# kube-vip — Control Plane Virtual IP
# ============================================================

# Virtual IP address for the K3s API server (must be free on the network)
k3s_vip: "192.168.1.10"

# Network interface on the nodes where the VIP will be announced (ARP mode)
k3s_vip_interface: "{{ ansible_default_ipv4.interface }}"

# kube-vip container image and version
kube_vip_image: "ghcr.io/kube-vip/kube-vip"
kube_vip_version: "v1.2.1"

# CIDR of the node network (control planes + workers). The kube-apiserver runs
# as a process on the nodes, so the cert-manager NetworkPolicy allows ingress
# from / egress to this CIDR (API on :6443, admission webhooks on :443).
node_cidr: "192.168.1.0/24"

# ============================================================
# Ceph CSI
# ============================================================

ceph_sc_rbd_name: "ceph-rbd"
ceph_sc_cephfs_name: "ceph-cephfs"

ceph_csi_operator_version: "v1.0.4"

# Ceph user (e.g., admin or kubernetes)
ceph_client_id: "admin"

# Ceph user secret key (e.g., client.admin or client.kubernetes)
ceph_client_key: "YOUR-CEPH-ADMIN-KEYRING-HERE"

# Ceph monitor IPs
ceph_monitors:
  - "192.168.1.200"
  - "192.168.1.201"
  - "192.168.1.202"

# Names of resources
ceph_rbd_pool: "pool1_ssd"
cephfs_fs_name: "cephfs1_ssd"

# CephFS subvolume group used by the CSI driver (must exist in Ceph)
cephfs_subvolumegroup: "csi"

# ============================================================
# MetalLB — LoadBalancer
# ============================================================

# MetalLB version to install
metallb_version: "v0.16.1"

# IP range for MetalLB to allocate to LoadBalancer services
# Must be on the same L2 network as the nodes and not overlap with DHCP/static IPs
metallb_ip_range: "192.168.1.150-192.168.1.199"

# Name of the MetalLB IP pool
metallb_pool_name: "default-pool"

# ============================================================
# Traefik (K3s-packaged Ingress Controller)
# ============================================================
# Kept enabled (not in k3s_disabled_components). Customized via a HelmChartConfig
# (templates/12-traefik-config.yml.j2): runs as a DaemonSet (one per node),
# redirects HTTP->HTTPS, enables the dashboard IngressRoute and drops the
# anonymous usage calls. The rest uses the chart defaults (websecure TLS on ->
# self-signed default cert). Only traefik_lb_ip is configurable here — it pins
# Traefik's LoadBalancer Service to a fixed MetalLB IP via the metallb.io
# annotation (the current prefix; metallb.universe.tf is deprecated since v0.14).
# See the README "Traefik" section.

# Fixed MetalLB IP for Traefik's LoadBalancer Service. Must be within
# metallb_ip_range and free. Last address of the pool by default.
traefik_lb_ip: "192.168.1.199"

# ============================================================
# cert-manager (optional) — real TLS via Let's Encrypt DNS-01
# ============================================================
# Flip certmanager_enabled to deploy cert-manager + Let's Encrypt ClusterIssuers
# (staging + prod). When false, nothing is installed and Traefik keeps its
# self-signed default cert. DNS providers (cloudflare built-in; ovh/infomaniak
# via webhooks, deployed only when a cred of that provider is present) are routed
# by domain. Tokens/keys are VAULT-protected (like ceph_client_key): put the real
# values in the gitignored all.yml, never in this committed example.
certmanager_enabled: false

# cert-manager release (official cert-manager.yaml is pulled from this tag).
certmanager_version: "v1.21.0"

# Email registered with Let's Encrypt (expiry notices).
certmanager_acme_email: "you@example.com"

# ACME servers -> one ClusterIssuer each. Staging issues untrusted certs with no
# rate-limit (use it for tests); prod issues real, browser-trusted certs.
certmanager_acme_servers:
  - name: "letsencrypt-staging"
    server: "https://acme-staging-v02.api.letsencrypt.org/directory"
  - name: "letsencrypt-prod"
    server: "https://acme-v02.api.letsencrypt.org/directory"

# DNS credentials -> one entry per (provider/token), routed by match_domains.
# Each entry creates a Secret in cert-manager and one dns01 solver inside every
# ClusterIssuer above; cert-manager picks the solver matching the Certificate's
# DNS names. Fields depend on the provider:
#   cloudflare : token
#   ovh        : endpoint, application_key, application_secret, consumer_key
#   infomaniak : token
certmanager_dns_credentials:
  - name: "cloudflare-main"
    provider: "cloudflare"
    secret_name: "cloudflare-api-token-main"
    token: "REDACTED"
    match_domains: ["example.tld", "*.example.tld"]
  - name: "ovh-other"
    provider: "ovh"
    secret_name: "ovh-creds-other"
    endpoint: "ovh-eu"
    application_key: "REDACTED"
    application_secret: "REDACTED"
    consumer_key: "REDACTED"
    match_domains: ["other.tld", "*.other.tld"]
  - name: "infomaniak-third"
    provider: "infomaniak"
    secret_name: "infomaniak-api-token-third"
    token: "REDACTED"
    match_domains: ["third.tld", "*.third.tld"]

# OVH webhook: groupName must match the webhook.groupName referenced by the OVH
# solvers. Choose a unique value (your own domain is recommended).
certmanager_webhook_group_ovh: "acme.myhomelab.example"
certmanager_webhook_ovh_chart_version: "0.9.14"
certmanager_webhook_ovh_chart_repo: "https://aureq.github.io/cert-manager-webhook-ovh"

# Infomaniak webhook: official rendered manifest (groupName acme.infomaniak.com
# is baked in by the publisher).
certmanager_webhook_infomaniak_version: "v0.3.1"

# ============================================================
# NFS CSI (optional) — access existing NFS shares (e.g. a NAS export)
# ============================================================
# Set nfs_enabled to true to deploy the kubernetes-csi NFS driver and one
# StorageClass per share listed in nfs_shares. When false, nothing is
# downloaded, installed or configured. The NFS driver has no operator — it is
# pulled as raw manifests, same pattern as MetalLB / ceph-csi-operator. Plain
# NFS needs no credentials.
nfs_enabled: false

# Release tag of kubernetes-csi/csi-driver-nfs
nfs_csi_version: "v4.13.4"

# Default mountOptions applied to every NFS StorageClass. A share can override
# these with its own mount_options field.
nfs_mount_options:
  - "nfsvers=4.1"

# One StorageClass is created per entry (cluster-scoped, named per share). Set
# the list to [] to deploy only the driver with no StorageClass. Each share:
#   name  -> StorageClass name (storageClassName to reference in a PVC)
#   server/share -> NFS server address and export path
#   mount_options -> optional, overrides nfs_mount_options for this share
nfs_shares:
  - name: "nfs-media"
    server: "nas.example.com"
    share: "/export/media"
  - name: "nfs-backup"
    server: "nas2.example.com"
    share: "/export/backup"
    mount_options:
      - "nfsvers=4.1"
      - "ro"

# ============================================================
# SMB CSI (optional) — access existing SMB/CIFS shares (e.g. a NAS)
# ============================================================
# Set smb_enabled to true to deploy the kubernetes-csi SMB driver and one
# StorageClass per share listed in smb_shares. When false, nothing is
# downloaded, installed or configured. Like NFS, the SMB driver has no operator
# — pulled as raw manifests.
#
# Credentials are ISOLATED PER NAMESPACE: each StorageClass resolves its Secret
# in the PVC's OWN namespace via the ${pvc.namespace} token. This baseline does
# NOT create that Secret — you create it (named smb_secret_name below) in every
# namespace that consumes an SMB share, when you set up that application. See
# the README for the manifest. The cluster all.yml therefore no longer holds
# SMB credentials; they live with each application (vault-protected there).
#
# NOTE: the SMB node plugin bundles cifs-utils in its container image, so no
# host package install is needed for username/password mounts. The host only
# needs the `cifs` kernel module (present on standard Ubuntu kernels). Host
# cifs-utils is required ONLY for Kerberos (sec=krb5) mounts.
smb_enabled: false

# Release tag of kubernetes-csi/csi-driver-smb
smb_csi_version: "v1.20.3"

# Name of the Secret the StorageClasses expect in each consuming namespace.
smb_secret_name: "csi-smb-creds"

# Default mountOptions applied to every SMB StorageClass. A share can override
# these with its own mount_options field. These defaults match the upstream
# example; noserverino is REQUIRED to avoid data corruption.
smb_mount_options:
  - "dir_mode=0777"
  - "file_mode=0777"
  - "noperm"
  - "mfsymlinks"
  - "cache=strict"
  - "noserverino"

# One StorageClass is created per entry (cluster-scoped, named per share). Set
# the list to [] to deploy only the driver with no StorageClass. Each share:
#   name -> StorageClass name (storageClassName to reference in a PVC)
#   source -> SMB share UNC path, e.g. //nas/photos
#   mount_options -> optional, overrides smb_mount_options for this share
smb_shares:
  - name: "smb-photos"
    source: "//nas.example.com/photos"
  - name: "smb-movies"
    source: "//nas.example.com/movies"

# ============================================================
# K3s — Auto-deployed Manifests
# ============================================================

# Manifests downloaded from URLs and placed in /var/lib/rancher/k3s/server/manifests/
k3s_server_manifests_urls:
  - url: "https://raw.githubusercontent.com/metallb/metallb/{{ metallb_version }}/config/manifests/metallb-native.yaml"
    filename: 03-metallb-native.yaml
  - url: "https://raw.githubusercontent.com/ceph/ceph-csi-operator/{{ ceph_csi_operator_version }}/deploy/multifile/crd.yaml"
    filename: 07-ceph-csi-operator-crd.yaml
  - url: "https://raw.githubusercontent.com/ceph/ceph-csi-operator/{{ ceph_csi_operator_version }}/deploy/multifile/csi-rbac.yaml"
    filename: 08-ceph-csi-operator-rbac.yaml
  - url: "https://raw.githubusercontent.com/ceph/ceph-csi-operator/{{ ceph_csi_operator_version }}/deploy/multifile/operator.yaml"
    filename: 09-ceph-csi-operator.yaml

# Manifests rendered from Jinja2 templates and placed in /var/lib/rancher/k3s/server/manifests/
k3s_server_manifests_templates:
  - 01-kube-vip-rbac.yml.j2
  - 02-kube-vip-daemonset.yml.j2
  - 04-metallb-config.yml.j2
  - 05-ceph-secrets.yml.j2
  - 06-ceph-storageclasses.yml.j2
  - 10-ceph-csi-operator-config.yml.j2
  - 11-network-policies.yml.j2
  - 12-traefik-config.yml.j2

# ------------------------------------------------------------
# Optional CSI driver manifests (NFS / SMB)
# ------------------------------------------------------------
# These sub-lists are NOT part of k3s_server_manifests_urls /
# k3s_server_manifests_templates by default. site.yml (pre_tasks) appends them
# to those lists only when the matching *_enabled flag is true. Inline {% if %}
# is not valid inside a YAML list in a vars file, which is why the conditional
# composition happens in the playbook rather than here. Keep the filenames
# numbered to slot after the baseline (network-policies = 11).
nfs_manifest_urls:
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/{{ nfs_csi_version }}/deploy/{{ nfs_csi_version }}/rbac-csi-nfs.yaml"
    filename: 12-nfs-rbac.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/{{ nfs_csi_version }}/deploy/{{ nfs_csi_version }}/csi-nfs-driverinfo.yaml"
    filename: 13-nfs-driverinfo.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/{{ nfs_csi_version }}/deploy/{{ nfs_csi_version }}/csi-nfs-controller.yaml"
    filename: 14-nfs-controller.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-nfs/{{ nfs_csi_version }}/deploy/{{ nfs_csi_version }}/csi-nfs-node.yaml"
    filename: 15-nfs-node.yaml
nfs_manifest_templates:
  - 20-nfs-storageclasses.yml.j2

smb_manifest_urls:
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-smb/{{ smb_csi_version }}/deploy/{{ smb_csi_version }}/rbac-csi-smb.yaml"
    filename: 16-smb-rbac.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-smb/{{ smb_csi_version }}/deploy/{{ smb_csi_version }}/csi-smb-driver.yaml"
    filename: 17-smb-driver.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-smb/{{ smb_csi_version }}/deploy/{{ smb_csi_version }}/csi-smb-controller.yaml"
    filename: 18-smb-controller.yaml
  - url: "https://raw.githubusercontent.com/kubernetes-csi/csi-driver-smb/{{ smb_csi_version }}/deploy/{{ smb_csi_version }}/csi-smb-node.yaml"
    filename: 19-smb-node.yaml
smb_manifest_templates:
  - 21-smb-storageclasses.yml.j2

# ------------------------------------------------------------
# Optional cert-manager manifests
# ------------------------------------------------------------
# Like NFS/SMB, these sub-lists are NOT part of k3s_server_manifests_urls /
# k3s_server_manifests_templates by default. site.yml (pre_tasks) appends them
# when certmanager_enabled is true. The DNS webhooks (OVH/Infomaniak) are added
# only when at least one credential of the matching provider is present
# (computed in site.yml from certmanager_dns_credentials).
certmanager_manifest_urls:
  - url: "https://github.com/cert-manager/cert-manager/releases/download/{{ certmanager_version }}/cert-manager.yaml"
    filename: 30-cert-manager.yaml
certmanager_manifest_templates:
  - 33-certmanager-dns-secrets.yml.j2
  - 34-certmanager-issuers.yml.j2
  - 35-certmanager-network-policies.yml.j2
  - 36-certmanager-webhook-secret-reader.yml.j2
certmanager_webhook_ovh_templates:
  - 32-certmanager-webhook-ovh.yml.j2
certmanager_webhook_infomaniak_urls:
  - url: "https://github.com/Infomaniak/cert-manager-webhook-infomaniak/releases/download/{{ certmanager_webhook_infomaniak_version }}/rendered-manifest.yaml"
    filename: 31-certmanager-webhook-infomaniak.yaml
