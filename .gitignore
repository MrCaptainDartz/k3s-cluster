## OpenTofu / Terraform ##

# Local directories
.terraform/

# Providers lock file
# You may want to commit this if you want to ensure the exact same provider versions are used across all machines.
# However, many teams ignore it and rely on version constraints in the configuration files instead. 
# Remove the `#` below if you want to ignore the lock file.
# .terraform.lock.hcl

# State files (never commit state files to git)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# passwords, private keys, and other secrets. These should not be part of version
# control as they vary per environment and often contain secrets.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore plan execution files
*.tfplan
*.plan

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files
.terraform.lock.hcl

# Ignore Ansible K3s inventory and variable files
ansible-k3s/inventory/hosts.yml
ansible-k3s/inventory/group_vars/all.yml

## OS & Editors ##
.DS_Store
.idea/
.vscode/
*.swp
*~
