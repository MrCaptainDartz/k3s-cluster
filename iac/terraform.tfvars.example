# Example file for sensitive data and configuration variables.
# Copy this file to 'terraform.tfvars' and fill in your values.

# ----------------------------------------------------------------
# Proxmox API (mandatory)
# ----------------------------------------------------------------
proxmox_api_url   = "https://10.x.x.x:8006/api2/json"
proxmox_api_token = "root@pam!opentofu=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Set to false if you have a valid TLS certificate on Proxmox
proxmox_insecure = true

# SSH user to access Proxmox nodes (default: root)
# proxmox_ssh_username = "root"

# ----------------------------------------------------------------
# SSH Access (mandatory)
# ----------------------------------------------------------------
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc... myuser@myworkstation"

# ----------------------------------------------------------------
# VM Configuration (optional — default values below)
# Each entry: node_name, and network_interfaces
# ----------------------------------------------------------------
# vm_config = {
#   "vm-hc1" = {
#     node_name = "srv-tlm-hc1"
#     network_interfaces = [
#       {
#         bridge  = "vmbr0"
#         address = "10.0.2.1/24"
#         gateway = "10.0.2.254"
#         # vlan_id = 10
#       },
#       {
#         bridge  = "vmbr_ceph"
#         address = "10.0.1.1/24"
#         # vlan_id = 20
#       }
#     ]
#   }
#   "vm-hc2" = {
#     node_name = "srv-tlm-hc2"
#     network_interfaces = [
#       {
#         bridge  = "vmbr0"
#         address = "10.0.2.2/24"
#         gateway = "10.0.2.254"
#       },
#       {
#         bridge  = "vmbr_ceph"
#         address = "10.0.1.2/24"
#       }
#     ]
#   }
#   "vm-hc3" = {
