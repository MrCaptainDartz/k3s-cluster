# ----------------------------------------------------------------
# Optional parameters (reasonable default values)
# ----------------------------------------------------------------

# Cloud-Init Image
# ubuntu_cloud_image_url      = "https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
# ubuntu_cloud_image_filename = "ubuntu-24.04-noble-server-cloudimg-amd64.img"
# image_datastore_id          = "local"

# VM Resources
# vm_machine_type      = "q35"     # "q35" (recommended for PCIe/UEFI) or "pc" (Legacy)
# vm_bios              = "seabios" # "seabios" or "ovmf" (UEFI)
# vm_vga_type          = "qxl"     # "qxl" (SPICE), "std" (Default), "serial0", "vmware"
# vm_keyboard_layout   = "fr"      # "fr", "en-us", etc.
# vm_cpu_cores         = 16
# vm_cpu_type          = "x86-64-v2-AES"
# vm_memory_mb         = 24576   # 24 GiB
# vm_disk_size_gb      = 120
# vm_disk_datastore_id = "local-lvm"

# Automatic Startup
# vm_start_on_boot = true

# Proxmox Tags
# vm_tags = ["k3s", "opentofu"]


# Cloud-Init user
# vm_user = "ubuntu"

# DNS configuration (optional)
# dns_servers = ["1.1.1.1", "1.0.0.1"]
# dns_domain  = "home.lan"
